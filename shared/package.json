{
  "name": "gas-city-dashboard-shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./gc-supervisor": {
      "types": "./dist/generated/gc-supervisor-client/index.d.ts",
      "default": "./dist/generated/gc-supervisor-client/index.js"
    },
    "./fixtures/test-city": {
      "types": "./dist/fixtures/test-city/index.d.ts",
      "default": "./dist/fixtures/test-city/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "license": "MIT",
  "author": "Charlie Coutts"
}
