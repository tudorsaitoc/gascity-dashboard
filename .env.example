# gas-city-dashboard env template.
#
# Copy this file to .env.local, edit, then source it before running the dev
# servers:
#
#   cp .env.example .env.local
#   # edit .env.local
#   set -a; . ./.env.local; set +a
#   npm run dev:backend
#
# .env.local is gitignored. .env.example is allow-listed. Do not commit
# secrets in either file: nothing here is a credential today, and that is the
# intended shape.
#
# Authoritative reference for every knob: backend/src/config.ts.

# --- Listener ----------------------------------------------------------------

# TCP port the dashboard listens on. Default 8081 (sits next to the gc
# dashboard on 8080).
# PORT=8081

# Bind interface. Default 127.0.0.1 (single-operator floor). Set 0.0.0.0
# only on a trusted LAN, and add the LAN names to ADMIN_EXTRA_ALLOWED_HOSTS.
# HOST=127.0.0.1

# CSV of extra hostnames allowed in the Host: header allow-list, on top of
# the always-present floor [127.0.0.1, localhost]. Used when HOST=0.0.0.0
# and clients reach the dashboard by LAN name/IP.
# ADMIN_EXTRA_ALLOWED_HOSTS=my-vm,192.168.1.58

# --- Gas City supervisor -----------------------------------------------------

# gc supervisor API base URL (no trailing slash).
# GC_SUPERVISOR_URL=http://127.0.0.1:8372

# Name of the city this dashboard manages. One dashboard per city.
# GC_CITY_NAME=gas-city

# Optional absolute path to the city directory, passed as `gc prime
# --city=<path>`. When unset, `gc` walks up from cwd to discover the city.
# Set this in headless or systemd contexts where cwd is unrelated to the
# city tree.
# GC_CITY_PATH=

# --- Storage paths -----------------------------------------------------------

# Where state-changing actions append audit entries. Defaults to
# $HOME/.gc/events.jsonl.
# ADMIN_AUDIT_LOG_PATH=/home/you/.gc/events.jsonl

# Path to built frontend assets. The production server reads this; dev
# does not need it.
# ADMIN_FRONTEND_DIST=../frontend/dist

# Repo (owner/name) the Activity view's `git log` queries run against.
# ADMIN_GIT_REPO=/home/you

# --- Kill switches -----------------------------------------------------------

# Refuse to start when set to "1". Useful for taking the dashboard offline
# without uninstalling the systemd unit.
# ADMIN_DASHBOARD_DISABLED=0

# Snapshot fixture mode: serves cached/fixture data instead of live gc calls
# when set to "1". Default off.
# SNAPSHOT_USE_FIXTURES=0

# --- Maintainer triage view --------------------------------------------------

# These knobs only matter if you use the maintainer triage view. The defaults
# point at gastownhall/gascity and refresh every six hours, which is the
# shipped operator's setup. External contributors usually leave these alone.

# Upstream repo the maintainer view fetches issues and PRs from.
# MAINTAINER_REPO=gastownhall/gascity

# Where the in-process enrichment cache is persisted.
# MAINTAINER_CACHE_PATH=/home/you/.gascity-dashboard/maintainer-cache.json

# Refresh interval in milliseconds. 0 disables the background worker
# (manual refresh only). Default 6h.
# MAINTAINER_REFRESH_INTERVAL_MS=21600000

# Default agent alias for `gc sling` dispatch (review/draft intents).
# Bad values fall back to 'mayor' with a console warning.
# MAINTAINER_SLING_TARGET=mayor

# Default agent alias for `gc sling` dispatch on intent='triage'. Routes
# to the chief-of-staff so they dispatch the appropriate project-lead.
# Bad values fall back to 'chief-of-staff' with a console warning.
# MAINTAINER_TRIAGE_TARGET=chief-of-staff

# --- Optional integrations ---------------------------------------------------

# GitHub token used by the maintainer view for `gh` calls that exceed the
# unauthenticated rate limit. Read-only scope is enough. If unset, the gh
# CLI falls back to whatever the host has configured.
# GITHUB_TOKEN=
