{
  "name": "gas-city-dashboard-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "ajv": "^6.15.0",
    "express": "^4.21.2",
    "gas-city-dashboard-shared": "*",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.6",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "license": "MIT",
  "author": "Charlie Coutts"
}
